# Local secrets template — copy to .env and fill in your own keys
# .env is gitignored; this template is committed.
#
# Usage: `cp .env.example .env && $EDITOR .env`
# Scripts will refuse to start if these are not set.

# === OpenAI (required for memory embeddings via text-embedding-3-small) ===
OPENAI_API_KEY=

# === HuggingFace (required for downloading Qwen2.5 / Llama models) ===
HF_TOKEN=

# === Gemini / Together (judge fallback if not using local gpt-oss-120b) ===
GEMINI_API_KEY=
TOGETHER_API_KEY=

# === Mem0 / Zep (only for OOD baselines) ===
MEM0_API_KEY=
MEM0_PROJECT_ID=
MEM0_ORGANIZATION_ID=
ZEP_API_KEY=

# === WandB ===
WANDB_API_KEY=

# === Defaults ===
MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
JUDGE_PROVIDER=together
