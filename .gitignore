# Testing pipelines: ignore only the heavy artifacts (vector DBs, big datasets, results, caches)
testing/results/
testing/*/qdrants/
testing/*/dataset/
testing/*/cache/
testing/*/__pycache__/
testing/*/wandb/
testing/*/.env
